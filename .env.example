NODE_ENV=development
PORT=4000

# Database (required)
DATABASE_URL=postgres://user:password@localhost:5432/ai_recommender

# Redis (optional in Phase 1, required in production)
REDIS_URL=redis://localhost:6379

# TMDB (required in Phase 1.5+)
TMDB_API_KEY=your_tmdb_key
TMDB_API_BASE=https://api.themoviedb.org/3

# Service URLs
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# Web client — copy this into apps/web/.env.local for local dev
NEXT_PUBLIC_API_URL=http://localhost:4000

# Logging
LOG_LEVEL=info

# Phase 2 placeholders — leave blank until needed
SESSION_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
